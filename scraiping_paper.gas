/** チェックする Arxiv の RSS リスト */
const URL_LIST = [
    "https://export.arxiv.org/rss/cs.DS",
    "https://export.arxiv.org/rss/cs.CC",
    "https://export.arxiv.org/rss/math.OC",
    "https://export.arxiv.org/rss/math.CO",
    "https://export.arxiv.org/rss/quant-ph"
];

/** チェックするキーワードのリスト */
const KEYWORD_LIST = ["combinatorial", "optimize", "np-hard"];
const PRIORITIZED_KEYWORD = ["np-hard"];

/** チェックする論文の最大本数 */
const MAX_NUM_PAPER = 6;

/** rate limit 回避のため (もう少し短くてもいいかも) */ 
const SLEEPING_SECS = 10000;

function main() {
  // メール本文
  let body = "";

  // 論文の情報をリストに格納
  console.info("load arxives");
  let infos = []
  URL_LIST.forEach(url => {
      infos = infos.concat(getArxivPapersInfo(url, false));
  });

  console.info("filter papers");

  var seen = new Set();
  infos = infos.filter(row => {
    const key = row[1]; // タイトル
    if (seen.has(key)) {
      return false; // 既に出たキーなら除外
    }
    seen.add(key);
    return true;
  });

  console.info("sort papers");

  // 日付でソート
  infos.sort((a, b) => {
    const dateA = a[0];
    const dateB = b[0];

    const hasKeywordA = PRIORITIZED_KEYWORD.some(keyword => a[2].toLowerCase().includes(keyword.toLowerCase()));
    const hasKeywordB = PRIORITIZED_KEYWORD.some(keyword => b[2].toLowerCase().includes(keyword.toLowerCase()));

    // キーワード優先（true = 1, false = 0）
    if (hasKeywordA !== hasKeywordB) {
      return hasKeywordB - hasKeywordA; // キーワードありを先頭に
    }

    // 日付で新しい順に
    return dateB - dateA;
  });

  console.info("post ChatGPT");

  for (let i = 0; i < infos.length; i++) {
    // 最大本数を超えた場合、終了
    if (i >= MAX_NUM_PAPER) {
      break;
    }
    // rate limit 回避のため、間でスリープ
    if (i > 0) {
      Utilities.sleep(SLEEPING_SECS);
    }

    // 論文情報をパース
    const [pubDate, title, abstract, link] = infos[i];

    // ChatGPT に要約してもらう
    const summary = summarizeAbstract(abstract); 

    // メール本文に要約を追記
    body += makeHtmlBody(title, summary, link);
  }

  // 論文がなかった場合はメール本文にその旨を記述
  if (infos.length == 0) {
    body = "今日は新しい論文がありませんでした。"
  }
  
  const email_subject = `Paper Digest - ${new Date().toDateString()}`;

  // メールを送信
  MailApp.sendEmail({
    to: EMAIL_RECIPIENT,
    subject: email_subject,
    htmlBody: body
  });
}

/**
 * RSSから昨日以降出版された論文の情報を最大 `max_num_paper` 本取得する
 * @param {string} rssURL RSSのURL (https://export.arxiv.org/rss/cs.DS)
 * @return {list} (出版時刻, タイトル, 概要, PDFへのリンク) のタプルのリスト
 */
function getArxivPapersInfo(rssUrl, onlyPublished=true) {
  const today = new Date();
  const yesterday = new Date(today);
  yesterday.setDate(today.getDate() - 1);

  let response;
  do {
    try {
      response = UrlFetchApp.fetch(rssUrl);
      break;
    } catch (e) {
      console.log(e);
      Utilities.sleep(SLEEPING_SECS);
    }
  } while (true);

  const xml = XmlService.parse(response.getContentText());
  const entries = xml.getRootElement().getChild("channel").getChildren("item");
  let infos = [];
  for (let i = 0; i < entries.length; i++) {
    const entry = entries[i];
    const title = entry.getChildText("title");
    const description = entry.getChildText("description");
    const submittedStr = entry.getChildText("pubDate");
    const abs_link = entry.getChildText("link");
    const pdf_link = abs_link.replace("abs", "pdf");

    // arXiv ID を抽出（例: https://arxiv.org/abs/2504.21624 → 2504.21624）
    const idMatch = abs_link.match(/\/abs\/([^\/]+)$/);
    if (!idMatch) continue;
    const arxivId = idMatch[1];

    // API 経由で submitted（published）日付を取得
    const apiUrl = `https://export.arxiv.org/api/query?id_list=${arxivId}`;
    let apiResponse;
    try {
      apiResponse = UrlFetchApp.fetch(apiUrl);
    } catch (e) {
      console.log("API fetch failed for:", arxivId, e);
      continue;
    }

    const apiXml = XmlService.parse(apiResponse.getContentText());
    const ns = XmlService.getNamespace("http://www.w3.org/2005/Atom");
    const entryNode = apiXml.getRootElement().getChild("entry", ns);
    const publishedStr = entryNode.getChildText("published", ns); // 例: "2025-04-30T00:00:00Z"
    const submittedDate = new Date(publishedStr);

    // 昨日以前の投稿は除外
    if (onlyPublished && submittedDate < yesterday) {
      continue;
    }
    if (!onlyPublished && new Date(submittedStr) < yesterday) {
      continue;
    }

    // abstract 抽出
    const abs_keyword = "Abstract: ";
    const abs_ind = description.indexOf(abs_keyword);
    if (abs_ind === -1) continue;
    const abstract = description.substring(abs_ind + abs_keyword.length);

    // キーワードにマッチするか判定
    const found = KEYWORD_LIST.some(keyword =>
      abstract.toLowerCase().includes(keyword.toLowerCase())
    );

    if (found) {
      infos.push([submittedDate, title, abstract, pdf_link]);
    }
  }

  return infos;
}

/**
 * ChatGPTを用いて論文の概要を要約する
 * @param {string} abstract 論文の概要
 * @return {string} 要約された概要
 */
function summarizeAbstract(abstract) {
  const prompt = `
<abstract_translation_request>
abstractタブ内は論文のアブストラクトです。日本語に翻訳してください。

<note>
- 平文で出力してください。
- 正確な翻訳を心がけ、論文に書かれていない推測は避けてください。
- タイトルは不要です。
- 読み手にわかりやすい文章構成を心がけ、論理的な流れを意識してください。
- 専門用語には説明を加えてください。
- 簡潔かつ明瞭な表現を使用してください。
</note>

<abstract>
${abstract}
</abstract>
<abstract_translation_request>
`;

  return getChatGPTResponse(prompt);
}

/**
 * メール本文に載せるために情報を整形して文字列で返す
 * @param {string} title 論文のタイトル
 * @param {string} summary 論文の概要
 * @param {string} link 論文のリンク
 */
function makeHtmlBody(title, summary, link) {
  let body = `<h2><a href="${link}">${title}</a></h2>
<p>${summary}</p>
<p>
<ul>`;

  for (let i = 0; i < QUERY_LIST.length; i++) {
    const [prompt, description] = QUERY_LIST[i];
    body += `<li><a href=${makeQuestionUrl(link, prompt)}>${description}</a></li>
`;
  }
  body += `</ul>
</p>
`;
  return body;
}

/**
 * ChatGPTに入力された内容を質問する
 * @param {string} promptText 質問内容
 * @return {string} 回答内容
 */
function getChatGPTResponse(promptText) {
  const payload = {
    model: "gpt-3.5-turbo",
    messages: [{ role: "user", content: promptText }],
    temperature: 0.7
  };
  const options = {
    method: 'post',
    contentType: 'application/json',
    headers: { Authorization: `Bearer ${OPENAI_API_KEY}` },
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  };
  const response = UrlFetchApp.fetch("https://api.openai.com/v1/chat/completions", options);
  const result = JSON.parse(response.getContentText());
  console.log(result);
  return result.choices[0].message.content.trim();
}

/**
 * ChatGPT への論文に関する質問 URL を作成する
 * @param {string} 論文の URL
 * @param {string} プロンプトテンプレート
 * @return {string} 質問内容が埋め込まれた URL
 */
function makeQuestionUrl(paperUrl, promptTemplate) {
  const prompt = `
  ${paperUrl}
  ${promptTemplate}
`

  return "https://chat.openai.com/?q=" + encodeURIComponent(prompt);
}

