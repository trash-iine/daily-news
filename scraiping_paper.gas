/**
 * メールに載せる質問リンクのリスト
 * (プロンプト, 説明文) のタプルのリスト
 * 不要なプロンプトはコメントアウトしてください
 */
const QUERY_LIST = [
  [SUMMARY_PROMPT, "より詳細な概要について質問する"],
  [METHOD_PROMPT, "論文の手法について質問する"],
  // [EQUATION_PROMPT, "論文内の数式について質問する"],
  // [DISCUSSION_PROMPT, "論文内の考察について質問する"],
  // [RELATED_PROMPT, "関連研究について質問する"],
];
